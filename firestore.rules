rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function authUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTeacher() {
      return isSignedIn() && authUser().exists() && authUser().data.role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && authUser().exists() && authUser().data.role == 'student';
    }

    function ownsUserDoc(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (ownsUserDoc(uid) || isTeacher());
      allow write: if isSignedIn() && ownsUserDoc(uid);

      match /progress/{comicId} {
        allow read: if isSignedIn() && (ownsUserDoc(uid) || isTeacher());
        allow write: if isSignedIn() && ownsUserDoc(uid);
      }
    }

    // ── reflection ───────────────────────────────────────────────────────────
    match /reflection/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.studentId == request.auth.uid
        || isTeacher()
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid
        || request.resource.data.studentId == request.auth.uid
      );
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.studentId == request.auth.uid
      );
    }

    match /activity/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isTeacher()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /application_activity/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isTeacher()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /identification_answers/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || isTeacher()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── comics ────────────────────────────────────────────────────────────
    // Metadata komik: read publik, write hanya via Admin SDK / seed script
    match /comics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Semua collection lain: tolak ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
